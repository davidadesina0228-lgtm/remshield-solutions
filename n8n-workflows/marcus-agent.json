  "name": "MARCUS — AI Lead Generation Agent",
  "nodes": [
    {
      "parameters": {
        "content": "## 🤖 MARCUS\n**Autonomous AI Lead Generation Agent**\n\nRuns every Monday 8AM UTC\n\n✅ Finds ICP-matched leads via Apollo.io\n✅ Scores & saves qualified leads to Google Sheets\n✅ Writes personalised cold emails\n✅ Sends via SMTP automatically\n✅ Self-logs learnings to improve each run\n\nBuilt by **RemShield Solutions**",
        "height": 300,
        "width": 320,
        "color": 4
      },
      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
      "name": "Sticky Note",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [-60, 120]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 8 * * 1"
            }
          ]
        }
      },
      "id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
      "name": "Every Monday 8AM UTC",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [300, 280]
    },
    {
      "parameters": {
        "systemMessage": "You are MARCUS, RemShield's autonomous AI lead generation agent. Your job is to find high-quality B2B leads, qualify them against our ICP, save them to our database, write personalised cold emails, send them, and log your learnings after each run.\n\nICP: Founders, CEOs, COOs, CTOs, Ops Directors at growth-stage companies (11-500 employees) with manual workflow pain points.\n\nTarget Markets: Nigeria, Ghana, Kenya, South Africa, USA, UK, Germany, Netherlands, Canada, Australia.\n\nRun sequence every Monday:\n1. Search Apollo for 10-15 fresh ICP-matched leads\n2. Read existing leads to avoid duplicates\n3. Score each new lead (0-10)\n4. Save qualified leads (score >= 7)\n5. Write personalised cold emails\n6. Send emails via SMTP\n7. Read previous learning log\n8. Save new learnings and observations for next run",
        "options": {}
      },
      "id": "c3d4e5f6-a7b8-9012-cdef-123456789012",
      "name": "MARCUS AI Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [640, 280]
    },
    {
      "parameters": {
